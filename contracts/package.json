{
  "name": "@relayx/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "RelayX smart contracts — Foundry project",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vv",
    "test:verbose": "forge test -vvvv",
    "test:coverage": "forge coverage",
    "test:gas": "forge test --gas-report",
    "lint": "forge fmt --check",
    "fmt": "forge fmt",
    "deploy:sepolia": "forge script script/Deploy.s.sol:DeployRelayXKey --rpc-url $SEPOLIA_RPC_URL --broadcast --verify --etherscan-api-key $ETHERSCAN_API_KEY -vvvv",
    "deploy:mainnet": "forge script script/Deploy.s.sol:DeployRelayXKey --rpc-url $MAINNET_RPC_URL --broadcast --verify --ledger --sender $RELAYX_OWNER --etherscan-api-key $ETHERSCAN_API_KEY -vvvv",
    "install:deps": "forge install OpenZeppelin/openzeppelin-contracts@v5.0.2 --no-git"
  }
}
