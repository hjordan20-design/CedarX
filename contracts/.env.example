# ─── Deployment keys ─────────────────────────────────────────────────────────
# Testnet only — use --ledger flag on mainnet instead
DEPLOYER_PRIVATE_KEY=0x...

# ─── Contract configuration ───────────────────────────────────────────────────
# Wallet that receives CedarX platform fees (use hardware wallet on mainnet)
CEDARX_TREASURY=0x...

# Contract owner (use a Gnosis Safe multisig on mainnet)
CEDARX_OWNER=0x...

# Platform fee in basis points (150 = 1.5%)
CEDARX_FEE_BPS=150

# ─── RPC endpoints ────────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Etherscan verification ───────────────────────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
