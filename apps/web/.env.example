# Indexer API URL
VITE_API_URL=http://localhost:3001

# CedarX swap contract (set after Sepolia deployment)
VITE_CEDARX_SWAP_CONTRACT_ADDRESS=

# Ethereum USDC address (mainnet — do not change)
VITE_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Alchemy API key for Polygon mainnet (Courtyard NFT scanning)
VITE_ALCHEMY_API_KEY=

# Alchemy API key for Ethereum mainnet (Fabrica / 4K NFT scanning).
# If not set, falls back to VITE_ALCHEMY_API_KEY (only safe when using a multi-chain key).
VITE_ALCHEMY_ETH_API_KEY=

# WalletConnect project ID (register at cloud.walletconnect.com — free)
VITE_WALLETCONNECT_PROJECT_ID=

# Mapbox public token — used for satellite image fallback on land asset cards
VITE_MAPBOX_TOKEN=
