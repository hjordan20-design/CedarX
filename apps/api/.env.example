# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase project URL (from project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (bypasses RLS — keep secret, server-side only)
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Alchemy API key (free tier: 300M compute units / month)
ALCHEMY_API_KEY=your-alchemy-api-key

# Which chain to index: "mainnet" or "sepolia"
CHAIN_ENV=mainnet

# ─── Contract addresses ───────────────────────────────────────────────────────
# Deployed CedarX swap contract (set after Session 2 deployment)
CEDARX_SWAP_CONTRACT_ADDRESS=0x...

# Fabrica (defaults already set in config.ts — override here if needed)
# FABRICA_CONTRACT_ADDRESS=0x8d96b4ab6c741a4c8679ae323a100d74f085ba8f

# Ondo (defaults already set in config.ts — override here if needed)
# ONDO_OUSG_ADDRESS=0x1b19c19393e2d034d8ff31ff34c81252fcbbee92
# ONDO_USDY_ADDRESS=0x96f6ef951840721adbf46ac996b59e0235cb985c
# ONDO_ROUSG_ADDRESS=0x6e9a65d98474f1c68406e2fe02695fe5a3e7cb0d

# RealT — comma-separated list (supplement to the runtime RealT API fetch)
# REALT_CONTRACT_ADDRESSES=0x...,0x...,0x...

# ─── Indexer behaviour ────────────────────────────────────────────────────────
# Poll interval in milliseconds (default: 180000 = 3 minutes)
POLL_INTERVAL_MS=180000

# How many blocks to scan per tick (Alchemy log limits vary by tier)
BLOCKS_PER_SCAN=2000

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://cedarx.io
