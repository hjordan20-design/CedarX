# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase project URL (from project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (bypasses RLS — keep secret, server-side only)
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Alchemy API key for Ethereum (mainnet + Sepolia)
ALCHEMY_API_KEY=your-alchemy-api-key

# Separate Alchemy key for Polygon Mainnet.
# Alchemy free-tier apps are network-specific — create a dedicated
# "Polygon Mainnet" app in the Alchemy dashboard and paste its key here.
# Falls back to ALCHEMY_API_KEY if not set (will return errors if ETH-only key).
ALCHEMY_POLYGON_API_KEY=your-polygon-alchemy-api-key

# Which chain the CedarX swap contract is deployed on: "mainnet" or "sepolia"
CHAIN_ENV=mainnet

# Override Polygon RPC entirely (optional — takes precedence over both keys above)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Contract addresses ───────────────────────────────────────────────────────
# CedarX swap contract — set after deployment
CEDARX_SWAP_CONTRACT_ADDRESS=0x...

# CedarX swap on Polygon (separate deployment — optional)
# CEDARX_SWAP_POLYGON_ADDRESS=0x...

# Protocol contract overrides (defaults already set in config.ts — verified addresses below)
#   Fabrica Token V2:       https://etherscan.io/token/0x8d96b4ab6c741a4c8679ae323a100d74f085ba8f
#   4K (ERC-1155):          https://etherscan.io/address/0xEBf19415d94be89A1d692F82af391685dC1Bff79
#   Courtyard NFT (Polygon): https://polygonscan.com/token/0x251be3a17af4892035c37ebf5890f4a4d889dcad
# FABRICA_CONTRACT_ADDRESS=0x8d96b4ab6c741a4c8679ae323a100d74f085ba8f
# FOURTK_CONTRACT_ADDRESS=0xEBf19415d94be89A1d692F82af391685dC1Bff79
# COURTYARD_CONTRACT_ADDRESS=0x251be3a17af4892035c37ebf5890f4a4d889dcad

# ─── Indexer behaviour ────────────────────────────────────────────────────────
# Poll interval in milliseconds (default: 180000 = 3 minutes)
POLL_INTERVAL_MS=180000

# How many blocks to scan per eth_getLogs request.
# Alchemy free tier: maximum 10 blocks per request.
BLOCKS_PER_SCAN=10

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://cedarx.io
