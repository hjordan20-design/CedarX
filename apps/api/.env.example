# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase project URL (from project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (bypasses RLS — keep secret, server-side only)
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Alchemy API key (used for Ethereum mainnet, Sepolia, and Polygon RPCs)
ALCHEMY_API_KEY=your-alchemy-api-key

# Which chain the CedarX swap contract is deployed on: "mainnet" or "sepolia"
CHAIN_ENV=mainnet

# Override Polygon RPC (defaults to Alchemy Polygon if not set)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Contract addresses ───────────────────────────────────────────────────────
# CedarX swap contract — set after deployment
CEDARX_SWAP_CONTRACT_ADDRESS=0x...

# CedarX swap on Polygon (separate deployment — optional)
# CEDARX_SWAP_POLYGON_ADDRESS=0x...

# Protocol contract overrides (defaults already set in config.ts)
# Verify these addresses before production:
#   Fabrica Token V2:  https://etherscan.io/token/0x8d96b4ab6c741a4c8679ae323a100d74f085ba8f
#   4K Genesis Keys:   https://etherscan.io/token/0x30015b88e33773bce3b8a32A93a13bA23CF91db3
#   Courtyard NFT:     https://polygonscan.com/token/0xd8a5a9b31c3c0232e196d518e89fd8bf83acad43
# FABRICA_CONTRACT_ADDRESS=0x8d96b4ab6c741a4c8679ae323a100d74f085ba8f
# FOURTK_CONTRACT_ADDRESS=0x30015b88e33773bce3b8a32A93a13bA23CF91db3
# COURTYARD_CONTRACT_ADDRESS=0xD8A5a9b31c3C0232E196d518E89Fd8bF83AcAd43

# ─── Indexer behaviour ────────────────────────────────────────────────────────
# Poll interval in milliseconds (default: 180000 = 3 minutes)
POLL_INTERVAL_MS=180000

# How many blocks to scan per tick (Alchemy free tier: keep ≤ 2000)
BLOCKS_PER_SCAN=2000

# ─── API server ───────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://cedarx.io
